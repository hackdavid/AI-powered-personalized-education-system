# ──────────────────────────────────────────────────────────────────────────
# Minimal .env for LOCAL DEVELOPMENT.
#
# This is the ONLY `.env` most teammates ever need. Paste the three real
# values at the top, `cp .env.local.example .env`, then:
#
#     pip install -r requirements.txt
#     python manage.py runserver
#
# Everything else (API keys, model names, URLs) comes from the shared
# `AppSetting` DB table — see docs/admin_setup.md for what's in there.
#
# If you want the fuller reference with every prod-only knob, see
# .env.example (same repo root).
# ──────────────────────────────────────────────────────────────────────────

# ─── REQUIRED ───

# Any random 50+ character string. Run:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=

# Must be True for local dev. When False, production security headers
# turn on (SSL redirect, HSTS, secure cookies) and runserver breaks.
DJANGO_DEBUG=True

# Ask Daud for the shared Supabase TRANSACTION-pooler URL. Looks like:
#   postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
#                                                                                        ^^^^
#                                                                            port 6543, not 5432
# Why port 6543: it's the transaction pooler and supports ~200 concurrent
# connections vs 15 on the session pooler (port 5432). For day-to-day dev
# always use 6543. Only flip to 5432 temporarily when running
# `python manage.py migrate`, then flip back.
#
# Leave blank only if you want a private local SQLite DB (you won't
# see any of the shared seeded data).
DATABASE_URL=

# ─── NICE-TO-HAVE (everything else lives in AppSetting / admin) ───

# If you ever hit HTTPS-related issues during dev, these can help:
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Default password for every seeded user (admins / teachers / students).
# Keep this as-is unless the seed was run with a different value.
SEED_DEFAULT_PASSWORD=Test@1234
