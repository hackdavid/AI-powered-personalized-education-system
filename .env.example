# Django Configuration
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
DB_NAME=eduai_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Redis Configuration (for Celery - future use)
# REDIS_URL=redis://localhost:6379/0

# AI Service Configuration
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_NAME=gpt-4
ANTHROPIC_API_KEY=your-anthropic-api-key
LLM_PROVIDER=openai

# Embedding Configuration
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# Vector Store Configuration
VECTOR_STORE_TYPE=chromadb
CHROMADB_PERSIST_DIR=chroma_data

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Email Configuration (Production)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@example.com
# EMAIL_HOST_PASSWORD=your-email-password
# DEFAULT_FROM_EMAIL=noreply@eduai.com

# Sentry Configuration (Production)
# SENTRY_DSN=your-sentry-dsn

# AWS S3 Configuration (for file storage in production)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=eduai-documents
# AWS_S3_REGION_NAME=us-east-1
