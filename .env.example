# EduAI platform — example environment file.
#
# Copy to `.env` in the same directory and fill in values. `.env` is
# gitignored and must NEVER be committed.
#
# Everything except DJANGO_SECRET_KEY is optional for local development:
# the app reads from the `AppSetting` DB table at startup (see
# docs/memory.md §14) and falls back to these env vars only when a row
# isn't present. Public / URL-style settings tend to live here; secret
# keys tend to live in admin.

# ─────────── Django ───────────
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ─────────── Database ───────────
# Paste the full connection URL here. Supabase gives it under
# Settings → Database → Connection string.
#
# Use the TRANSACTION POOLER URL (port 6543) — it supports ~200
# concurrent connections, vs 15 on the session pooler (port 5432).
# Only flip to 5432 temporarily when running `python manage.py migrate`,
# then flip back.
#
# Passwords with `@` / `/` / `#` must be URL-encoded (`@` → `%40`).
#
# Leave blank while DJANGO_DEBUG=True to fall back to a local SQLite
# file at db.sqlite3. When DJANGO_DEBUG=False the app refuses to boot
# without DATABASE_URL.
DATABASE_URL=

# ─────────── Embedding service ───────────
# Remote embedder (default). Set EMBEDDING_PROVIDER=local and uncomment
# `sentence-transformers` in requirements.txt if you prefer in-process.
EMBEDDING_PROVIDER=remote
EMBEDDER_API_URL=https://<your-user>-<space>.hf.space
EMBEDDER_API_KEY=
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# ─────────── LLM ───────────
# Leave OPENAI_API_KEY blank to keep the tutor in offline-stub mode.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_NAME=gpt-4
ANTHROPIC_API_KEY=
LLM_PROVIDER=openai

# ─────────── Vector store ───────────
# Only `pgvector` is supported right now (lives in Supabase via the
# DATABASE_URL above). Kept as an env var for future backend swaps.
VECTOR_STORE_TYPE=pgvector

# ─────────── CORS ───────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─────────── Production-only (ignored when DJANGO_DEBUG=True) ───────────
# Redis cache; falls back to locmem if absent.
# REDIS_URL=redis://127.0.0.1:6379/1

# Email backend; falls back to console in dev.
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@eduai.com

# Sentry error tracking; only active when DJANGO_DEBUG=False and set.
# SENTRY_DSN=

# Log file path (defaults to ./logs/app.log if blank).
# LOG_FILE=

# ─────────── Seeding ───────────
# Default password for every user created by seed_synthetic_data.
SEED_DEFAULT_PASSWORD=Test@1234
